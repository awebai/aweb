POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

# The default Docker Compose stack publishes only the aweb API to the host.
# awid stays on the internal Compose network unless you expose it explicitly.
AWEB_PORT=8000
APP_ENV=development

# Identity registry origin.
# Runtime default outside Compose: https://api.awid.ai
# Docker Compose default: http://awid:8010
# Self-hosters should run awid separately and point AWEB at its HTTP origin.
AWID_REGISTRY_URL=

# Signs payloads on behalf of custodial agents.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_CUSTODY_KEY=

# Managed permanent-address domain, e.g. aweb.example.com.
# This chooses the domain used for server-managed permanent addresses.
AWEB_MANAGED_DOMAIN=

# Signs namespace/address registrations for managed permanent addresses.
# Required when AWEB_MANAGED_DOMAIN is set and aweb talks to an awid registry,
# including the default self-hosted awid service in Docker Compose.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_NAMESPACE_CONTROLLER_KEY=

AWEB_LOG_JSON=true

POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

# The default Docker Compose stack publishes only the aweb API to the host.
# awid stays on the internal Compose network unless you expose it explicitly.
AWEB_PORT=8000
APP_ENV=development

# Identity registry origin.
# Runtime default outside Compose: https://api.awid.ai
# Docker Compose default: http://awid:8010
# Self-hosters should run awid separately and point AWEB at its HTTP origin.
AWID_REGISTRY_URL=

# Shared secret for verifying dashboard-issued JWTs.
AWEB_DASHBOARD_JWT_SECRET=

AWEB_LOG_JSON=true

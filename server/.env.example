# Docker Compose uses these to build the Postgres URLs for both aweb and awid.
POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

# Direct runtime alternative outside Compose:
# DATABASE_URL=postgresql://aweb:change-me@localhost:5432/aweb
# AWEB_DATABASE_URL=postgresql://aweb:change-me@localhost:5432/aweb
# REDIS_URL=redis://localhost:6379/0
# AWEB_REDIS_URL=redis://localhost:6379/0

# The default Docker Compose stack publishes aweb on localhost:8000 and awid on
# localhost:8010. Override AWEB_PORT and AWID_PORT here if those host ports are
# already in use.
AWEB_HOST=0.0.0.0
AWEB_PORT=8000
AWID_PORT=8010
APP_ENV=development

# Identity registry origin.
# Runtime default outside Compose: https://api.awid.ai
# Docker Compose default: http://awid:8010
# Self-hosters should run awid separately and point AWEB at its HTTP origin.
AWID_REGISTRY_URL=

# Shared secret for verifying dashboard-issued JWTs.
AWEB_DASHBOARD_JWT_SECRET=

AWEB_LOG_LEVEL=info
AWEB_LOG_JSON=true
AWEB_RELOAD=false

# Optional runtime tuning.
AWEB_PRESENCE_TTL_SECONDS=1800
AWEB_DATABASE_USES_TRANSACTION_POOLER=false
# AWEB_DATABASE_STATEMENT_CACHE_SIZE=

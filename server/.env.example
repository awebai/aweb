POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

# Only the aweb API is published to the host by default.
AWEB_PORT=8000

# Identity registry (default: https://api.awid.ai)
# Set to 'local' for embedded mode (air-gapped, no external registry).
AWID_REGISTRY_URL=

# Signs payloads on behalf of custodial agents.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_CUSTODY_KEY=

# Managed permanent-address domain, e.g. aweb.example.com
AWEB_MANAGED_DOMAIN=

# Signs namespace/address registrations for managed permanent addresses.
# Required when AWID_REGISTRY_URL is external and AWEB_MANAGED_DOMAIN is set.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_NAMESPACE_CONTROLLER_KEY=

AWEB_LOG_JSON=true

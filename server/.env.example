POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

# Only the aweb API is published to the host by default.
AWEB_PORT=8000

# Optional but recommended for custodial signing.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_CUSTODY_KEY=

# Optional managed namespace domain, e.g. aweb.example.com
AWEB_MANAGED_DOMAIN=

AWEB_LOG_JSON=true
